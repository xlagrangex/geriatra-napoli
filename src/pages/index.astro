---
import Base from "../layouts/Base.astro";

const wa = "https://wa.me/393384979120";
const uploads = "/wp-content/uploads/2025/06";

const services = [
  {
    title: "Urgenze non emergenziali dell'anziano",
    desc: "Interventi rapidi per gestire sintomi acuti o situazioni critiche che non richiedono accesso al pronto soccorso: confusione mentale, allucinazioni, cadute senza trauma, febbre e dolori improvvisi.",
    img: `${uploads}/Group-366-1.png`,
  },
  {
    title: "Gestione delle comorbidità e trattamenti plurifarmacologici",
    desc: "Valutazione clinica integrata per pazienti con più patologie croniche e revisione delle terapie in corso, per ridurre interazioni farmacologiche e ottimizzare l'aderenza al trattamento.",
    img: `${uploads}/Group-368.png`,
  },
  {
    title: "Cure palliative domiciliari",
    desc: "Assistenza dedicata al controllo dei sintomi e al supporto del paziente fragile o in fase avanzata di malattia, garantendo dignità, comfort e vicinanza alla famiglia.",
    img: `${uploads}/Group-374.png`,
  },
  {
    title: "Prevenzione delle fragilità",
    desc: "Interventi mirati a ridurre il rischio di decadimento fisico e cognitivo nell'anziano: valutazioni multidimensionali, consigli terapeutici, piani di mantenimento funzionale e autonomia.",
    img: `${uploads}/Group-373.png`,
  },
];

const patNeuro = { name: "Disturbi Neurologici", desc: "Demenze (Cerebrovascolari, Alzheimer, Parkinson, Demenza a Corpi di Lewy), ictus, idrocefalo, neuropatie centrali e periferiche.", icon: "Anxiety-1.png" };
const patFegato = { name: "Malattie del Fegato", desc: "Malattie croniche del fegato, cirrosi, edemi.", icon: "Liver-Failure-1.png" };
const patCardio = { name: "Malattie Cardiovascolari", desc: "Cardiopatie ischemiche, ipertensione, insufficienza cardiaca, aritmie.", icon: "Medical-Heart.png" };
const patResp = { name: "Malattie Respiratorie", desc: "BPCO, enfisema, asma, insufficienza respiratoria, bronchiti acute, polmoniti.", icon: "Respiratory-System.png" };
const patEmato = { name: "Malattie ematologiche", desc: "Anemia, tumori del sangue (leucemie e linfomi).", icon: "Coronavirus.png" };
const patAllett = { name: "Sindromi da allettamento", desc: "Perdita di forza muscolare, sarcopenia, rigidità articolare, contratture, trombosi venosa, edema agli arti, rischio di polmoniti, perdita di appetito, stipsi, malnutrizione, incontinenza sfinterica, ulcere da decubito.", icon: "Empty-Bed.png" };
const patPsich = { name: "Disturbi Psichiatrici", desc: "Delirio, psicosi secondarie, agitazione psico-motoria, allucinazioni, ansia, depressione, insonnia.", icon: "Straitjacket.png" };
const patEndo = { name: "Malattie endocrine", desc: "Diabete di tipo 2, distiroidismi.", icon: "Thyroid-Gland.png" };
const patRenali = { name: "Malattie Renali", desc: "Insufficienza renale cronica, squilibri elettrolitici.", icon: "Kidneys.png" };
const patOsteo = { name: "Malattie osteoarticolari", desc: "Artrite reumatoide, gotta, artrosi, osteoporosi.", icon: "Bone.png" };

const patologieColumns = [
  [patNeuro, patResp, patPsich],
  [patFegato, patEmato, patEndo, patOsteo],
  [patCardio, patAllett, patRenali],
];

const steps = [
  { n: "01", title: "Contatto diretto", desc: "È possibile richiedere informazioni o prenotare una visita scrivendo su WhatsApp o telefonando." },
  { n: "02", title: "Organizzazione della visita", desc: "Quando possibile, l'appuntamento viene fissato in giornata. In alternativa, viene concordata la data più adatta, compatibilmente con le disponibilità dello studio." },
  { n: "03", title: "Assistenza dopo la visita", desc: "Lo studio resta a disposizione per fornire chiarimenti, aggiornamenti o indicazioni successive, assicurando continuità e attenzione nel tempo." },
];

const faqs = [
  { q: "Come si svolge una visita geriatrica?", a: "Durante la visita vengono valutate le condizioni cliniche generali, i farmaci assunti, le abitudini quotidiane e le eventuali difficoltà. Segue un piano personalizzato in base ai bisogni." },
  { q: "Serve la prescrizione del medico di base?", a: "No, è possibile richiedere direttamente una visita geriatrica senza impegnativa del medico curante." },
  { q: "In quanto tempo viene fissata la visita?", a: "Generalmente in giornata o entro poche ore dalla richiesta, in base alla disponibilità e alla tipologia di bisogno." },
  { q: "In quali zone è disponibile il servizio domiciliare?", a: "Il servizio è attivo a Napoli, nella provincia, sulle isole e, su richiesta, anche in zone adiacenti da concordare." },
  { q: "È possibile prenotare per un genitore anche se si vive in un'altra città?", a: "Sì, è possibile. È consentito prenotare il servizio per un genitore anche se si risiede in un'altra città." },
  { q: "Dopo la visita, è previsto un supporto continuo?", a: "Sì, viene garantita la disponibilità per chiarimenti, monitoraggio dell'evoluzione clinica e aggiornamenti sul piano terapeutico." },
];
---

<Base title="Dott. Antonio Casale — Specialista in Geriatria a Napoli" description="Assistenza geriatrica a domicilio a Napoli. Visite specialistiche, gestione delle comorbidità, cure palliative e prevenzione delle fragilità.">

  <!-- HERO -->
  <section class="px-3 md:px-4">
    <div class="relative text-white overflow-hidden min-h-[720px] md:min-h-[820px] bg-[var(--color-brand)] rounded-b-[16px] md:rounded-b-[20px]">
    <img
      src={`${uploads}/Group-364-9.png`}
      alt="Dott. Antonio Casale"
      class="absolute inset-0 w-full h-full object-cover object-[70%_center] md:object-[65%_center]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-brand)] from-30% via-[var(--color-brand)]/85 via-50% to-transparent to-75%"></div>
    <div class="absolute inset-0 md:hidden bg-[var(--color-brand)]/55"></div>

    <div class="container-site relative min-h-[720px] md:min-h-[820px] grid md:grid-cols-2 gap-10 items-center">
      <div class="max-w-xl py-24 md:py-0">
        <h1 class="text-5xl md:text-[72px] font-normal leading-[1.05] tracking-tight">
          Assistenza geriatrica<br/>a domicilio
        </h1>
        <p class="mt-7 text-base md:text-lg text-white/85 leading-relaxed max-w-md">
          Ogni intervento è studiato per offrire continuità, sicurezza e attenzione alla persona anziana, direttamente a casa.
        </p>
        <div class="mt-9 flex flex-col sm:flex-row gap-5 sm:items-center">
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-[#5AB0F2] hover:bg-[#3FA0E8] text-white rounded-lg px-7 py-3.5 text-[15px] font-medium transition-colors w-fit">
            Contattaci ora via WhatsApp
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.886 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
          </a>
          <span class="inline-flex items-center gap-2 text-sm text-white/90">
            <span class="w-5 h-5 rounded-full bg-[#5AB0F2] flex items-center justify-center shrink-0">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            Competenza medica garantita
          </span>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- SERVIZI -->
  <section class="section">
    <div class="container-site">
      <div class="mb-12 max-w-2xl">
        <span class="kicker">Servizi</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-medium tracking-tight">Servizi specialistici dedicati alla salute dell'anziano</h2>
        <p class="mt-4 text-[var(--color-ink-3)]">Ogni intervento è pensato per garantire continuità, sicurezza e qualità nella gestione clinica dell'età avanzata.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {services.map((s) => (
          <a href={wa} target="_blank" rel="noopener" class="group relative aspect-square rounded-xl overflow-hidden block">
            <img src={s.img} alt={s.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />

            <!-- inner overlay box: top-flush, rounded only at bottom, with side+bottom inset -->
            <div class="absolute top-0 left-3 right-3 bottom-3 md:left-4 md:right-4 md:bottom-4 rounded-b-[16px] overflow-hidden pointer-events-none">
              <!-- default state gradient (top blue → transparent) -->
              <div class="absolute inset-x-0 top-0 h-1/2 bg-gradient-to-b from-[var(--color-brand)]/65 via-[var(--color-brand)]/20 to-transparent transition-opacity duration-300 group-hover:opacity-0"></div>
              <!-- hover state full blue gradient inside the inner box -->
              <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-brand)]/95 via-[var(--color-brand)]/85 to-[var(--color-brand)]/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

              <div class="absolute top-0 left-0 right-0 p-7 md:p-10">
                <h3 class="text-white text-2xl md:text-[32px] font-medium leading-[1.15] max-w-2xl drop-shadow-sm">{s.title}</h3>
                <p class="mt-5 md:mt-6 text-white/90 text-[15px] md:text-[17px] leading-relaxed max-w-2xl opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 delay-75">{s.desc}</p>
              </div>

              <div class="absolute bottom-6 left-7 md:bottom-8 md:left-10 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 delay-150">
                <span class="inline-flex items-center bg-white text-[var(--color-ink-1)] rounded-lg px-7 py-3.5 text-[15px] md:text-[16px] font-medium shadow-sm">
                  Prenota un appuntamento
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PATOLOGIE -->
  <section class="section">
    <div class="container-site">
      <div class="mb-12 max-w-2xl">
        <span class="kicker">Orientamento clinico</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-medium tracking-tight">Patologie Geriatriche Comuni</h2>
        <p class="mt-4 text-[var(--color-ink-3)]">Una panoramica delle condizioni cliniche più frequenti nell'età avanzata.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        {patologieColumns.map((col) => (
          <div class="flex flex-col gap-8 md:gap-10">
            {col.map((p) => (
              <div class="bg-white rounded-xl p-6 md:p-7 transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-lg">
                <div class="w-14 h-14 rounded-xl bg-[#D6EEFF] flex items-center justify-center mb-5">
                  <img src={`${uploads}/${p.icon}`} alt="" class="w-8 h-8 object-contain" loading="lazy" />
                </div>
                <h3 class="text-[22px] md:text-[24px] font-semibold leading-tight text-[var(--color-ink-1)] mb-3">{p.name}</h3>
                <p class="text-[15px] text-[var(--color-ink-3)] leading-relaxed">{p.desc}</p>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COME FUNZIONA -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="kicker">Come funziona</span>
        <h2 class="mt-5 text-3xl md:text-5xl font-medium tracking-tight text-[var(--color-brand)]">Un percorso semplice, umano e diretto.</h2>
        <p class="mt-5 text-[var(--color-ink-3)]">Ogni fase viene seguita con precisione, per garantire organizzazione e continuità.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-2">
        {steps.map((st) => (
          <div class="bg-[#D6EEFF] rounded-md p-10 md:p-12">
            <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-[var(--color-brand)] font-semibold text-sm mb-10">{st.n}</div>
            <div class="flex items-start justify-between gap-4 mb-5">
              <h3 class="text-2xl md:text-[26px] font-medium text-[var(--color-brand)] leading-tight">{st.title}</h3>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-[var(--color-brand)] shrink-0 mt-1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </div>
            <p class="text-[15px] text-[var(--color-brand)]/80 leading-relaxed">{st.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PERCHÉ SCEGLIERMI -->
  <section class="section">
    <div class="container-site grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div>
        <span class="kicker">Perché scegliermi</span>
        <h2 class="mt-6 text-4xl md:text-5xl font-medium leading-[1.1] tracking-tight text-[var(--color-brand)]">Esperienza clinica e attenzione alla persona, direttamente a casa</h2>
        <p class="mt-6 text-[var(--color-brand)]/80 leading-relaxed max-w-md">Il mio impegno è offrire assistenza geriatrica professionale e continua, con interventi domiciliari pensati per garantire sicurezza, rispetto e qualità di vita a ogni paziente anziano.</p>
        <ul class="mt-10 space-y-4">
          {[
            "Medico internista specializzato in geriatria",
            "Attività clinica privata a Napoli (Vomero)",
            "Visite domiciliari per anziani e pazienti fragili",
          ].map((item) => (
            <li class="flex items-center gap-4 text-[var(--color-brand)]">
              <span class="w-6 h-6 rounded-full bg-[#5AB0F2] flex items-center justify-center shrink-0">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="text-base md:text-[17px] font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="relative h-[560px] md:h-[660px]">
        <img
          src={`${uploads}/aiuto-anziani.png`}
          alt="Dott. Antonio Casale"
          class="absolute top-0 left-0 w-[62%] h-[80%] object-cover rounded-md shadow-md"
          loading="lazy"
        />
        <img
          src={`${uploads}/3a863701-e0c8-454a-83a3-00e9fd756d89-1.png`}
          alt="Visita geriatrica a domicilio"
          class="absolute top-[28%] right-0 w-[52%] h-[64%] object-cover rounded-md shadow-md"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="kicker">FAQs</span>
        <h2 class="mt-5 text-4xl md:text-5xl font-medium tracking-tight text-[var(--color-brand)]">Domande frequenti</h2>
        <p class="mt-5 text-[var(--color-brand)]/75 leading-relaxed">Informazioni utili per orientarsi e comprendere come si svolgono le visite, i servizi e l'assistenza nel tempo.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-x-16 gap-y-2 max-w-5xl mx-auto">
        {faqs.map((f, i) => (
          <details class="group py-6">
            <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
              <span class="text-[17px] md:text-[19px] font-medium text-[var(--color-brand)] leading-snug">{String(i + 1).padStart(2, "0")}. {f.q}</span>
              <svg width="14" height="16" viewBox="0 0 14 16" fill="#5AB0F2" class="shrink-0 transition-transform group-open:rotate-90"><path d="M0 0 L14 8 L0 16 Z"/></svg>
            </summary>
            <p class="mt-4 text-[15px] text-[var(--color-brand)]/75 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTATTI -->
  <section class="section">
    <div class="container-site grid md:grid-cols-2 gap-12 md:gap-16 items-stretch">
      <div class="flex flex-col">
        <span class="kicker">Contattaci</span>
        <h2 class="mt-6 text-4xl md:text-5xl font-medium leading-[1.1] tracking-tight text-[var(--color-brand)]">Richiedere assistenza o informazioni è semplice</h2>
        <p class="mt-6 text-[var(--color-brand)]/80 leading-relaxed max-w-md">Per ricevere indicazioni sui servizi offerti o fissare una visita, è possibile contattare direttamente lo studio.</p>
        <div class="mt-10 space-y-5 flex-1">
          <div class="bg-white rounded-md p-7 flex items-center gap-6">
            <div class="w-16 h-16 rounded-md bg-[#D6EEFF] flex items-center justify-center shrink-0">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="text-[#5AB0F2]"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h4 class="text-[20px] md:text-[22px] font-medium text-[var(--color-brand)]">Studio privato, Vomero (Napoli)</h4>
              <p class="text-[15px] text-[var(--color-brand)]/75 mt-2 leading-relaxed">Lo studio riceve su appuntamento. Informazioni dettagliate su orari e disponibilità verranno fornite al momento della richiesta.</p>
            </div>
          </div>
          <a href={wa} target="_blank" rel="noopener" class="bg-white rounded-md p-7 flex items-center gap-6 hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-md bg-[#D6EEFF] flex items-center justify-center shrink-0">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="text-[#5AB0F2]"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h4 class="text-[20px] md:text-[22px] font-medium text-[var(--color-brand)]">338 497 9120</h4>
              <p class="text-[15px] text-[var(--color-brand)]/75 mt-2 leading-relaxed">Numero diretto per contatti via WhatsApp o telefonici. La gestione delle richieste avviene in tempi rapidi.</p>
            </div>
          </a>
        </div>
      </div>
      <div class="bg-white rounded-md p-3 md:p-4 min-h-[520px]">
        <iframe
          src="https://maps.google.com/maps?q=Vomero%20%28Napoli%29&t=m&z=14&output=embed&iwloc=near"
          title="Vomero (Napoli)"
          aria-label="Vomero (Napoli)"
          class="w-full h-full min-h-[500px] border-0 rounded-sm"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

</Base>
