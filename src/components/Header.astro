        <span class="text-[18px] md:text-[22px] font-medium text-[var(--color-ink-1)] truncate">
          <span class="hidden sm:inline">Dott. Antonio Casale - Specialista in Geriatria</span>
          <span class="sm:hidden">Dott. A. Casale</span>
        </span>
      </a>
      <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[var(--color-brand)] hover:bg-[var(--color-brand-deep)] text-white rounded-lg px-5 md:px-6 py-2.5 md:py-3 text-[14px] md:text-[15px] font-medium transition-colors whitespace-nowrap shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.886 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
        <span class="hidden sm:inline">Contattaci ora via Whatsapp</span>
        <span class="sm:hidden">WhatsApp</span>
      </a>
    </div>
  </div>
</header>

<style>
  [data-header].is-hidden { transform: translateY(-110%); }
</style>

<script>
  const initStickyHeader = () => {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (!header) return;
    if ((header as any).__bound) return;
    (header as any).__bound = true;

    let lastY = window.scrollY;
    let ticking = false;
    const SHOW_THRESHOLD = 80;

    const update = () => {
      const y = window.scrollY;
      const delta = y - lastY;

      if (y < SHOW_THRESHOLD) {
        header.classList.remove("is-hidden");
      } else if (delta > 4) {
        header.classList.add("is-hidden");
      } else if (delta < -4) {
        header.classList.remove("is-hidden");
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initStickyHeader, { once: true });
  } else {
    initStickyHeader();
  }
  document.addEventListener("astro:page-load", initStickyHeader);
</script>
