---
import Base from "./Base.astro";

interface Props {
  zona: string;
  zonaLong?: string;
  title: string;
  description: string;
  intro: string;
  slug: string;
  cap?: string;
  travelMin?: string;
}

const { zona, zonaLong, title, description, intro, slug, cap, travelMin } = Astro.props;
const wa = "https://wa.me/393384979120";

const siteUrl = "https://geriatranapoli.com";
const pageUrl = `${siteUrl}/${slug}`;

const physicianSchema = {
  "@context": "https://schema.org",
  "@type": "Physician",
  "@id": `${pageUrl}#physician`,
  "name": "Dott. Antonio Casale",
  "alternateName": `Geriatra ${zona}`,
  "description": `Visite geriatriche a domicilio a ${zonaLong ?? zona} (Napoli). Dott. Antonio Casale, specialista in Geriatria.`,
  "url": pageUrl,
  "telephone": "+39-338-497-9120",
  "medicalSpecialty": "Geriatric",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Vomero",
    "addressLocality": "Napoli",
    "addressRegion": "NA",
    "postalCode": "80129",
    "addressCountry": "IT",
  },
  "areaServed": {
    "@type": "Place",
    "name": zonaLong ?? zona,
    ...(cap ? { "address": { "@type": "PostalAddress", "postalCode": cap, "addressLocality": "Napoli", "addressCountry": "IT" } } : {}),
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": title, "item": pageUrl },
  ],
};
---

<Base title={title} description={description}>
  <section class="px-3 md:px-4">
    <div class="relative bg-[var(--color-brand)] text-white overflow-hidden rounded-b-[16px] md:rounded-b-[20px]">
      <div class="container-site pt-44 md:pt-52 pb-20 md:pb-24">
        <span class="kicker" style="background: rgba(255,255,255,0.12); color: #ffffff;">Zone servite · Napoli</span>
        <h1 class="mt-6 text-4xl md:text-6xl font-normal leading-[1.05] tracking-tight max-w-3xl">{title}</h1>
        <p class="mt-7 text-base md:text-lg text-white/85 leading-relaxed max-w-2xl">{intro}</p>

        <div class="mt-10 flex flex-col sm:flex-row gap-5 sm:items-center">
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-[#5AB0F2] hover:bg-[#3FA0E8] text-white rounded-lg px-7 py-3.5 text-[15px] font-medium transition-colors w-fit">
            Prenota su WhatsApp
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.886 9.884"/></svg>
          </a>
          <span class="inline-flex items-center gap-2 text-sm text-white/90">
            <span class="w-5 h-5 rounded-full bg-[#5AB0F2] flex items-center justify-center shrink-0">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            {travelMin ? `~${travelMin} min dallo studio (Vomero)` : "Visite a domicilio su appuntamento"}
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site max-w-3xl">
      <article class="legal-prose">
        <slot />

        <hr />

        <h2>Prenotare una visita</h2>
        <p>
          Per richiedere una visita a {zonaLong ?? zona}, è possibile contattare lo studio via WhatsApp o telefonicamente al
          <a href="tel:+393384979120">338 497 9120</a>. Quando possibile l'appuntamento viene fissato in giornata, in alternativa
          viene concordata la data più adatta in base alle disponibilità.
        </p>

        <h2>Altre zone servite</h2>
        <ul>
          <li><a href="/geriatra-vomero">Geriatra a Vomero</a></li>
          <li><a href="/geriatra-chiaia">Geriatra a Chiaia</a></li>
          <li><a href="/geriatra-posillipo">Geriatra a Posillipo</a></li>
          <li><a href="/geriatra-isole-golfo-napoli">Geriatra nelle isole del Golfo (Capri, Ischia, Procida)</a></li>
        </ul>
      </article>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(physicianSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>
